# =============================================================================
# Home Assistant — paste your real values ONLY below (one place for the whole repo)
# =============================================================================
# 1) Copy this file next to it as home_assistant.secrets.env (gitignored):
#      cp home_assistant.secrets.env.example home_assistant.secrets.env
# 2) Replace the two quoted strings with your HA IP/hostname and long-lived token.
# 3) Before starting VOLTTRON or running integration tests, load it:
#      cd /path/to/volttron
#      set -a && source home_assistant.secrets.env && set +a
#    Or from anywhere:
#      set -a && source /path/to/volttron/services/core/PlatformDriverAgent/tests/load_home_assistant_secrets.env && set +a
#
# light.bed_light.config uses ${HOME_ASSISTANT_*}; pytest uses the aliases below.

export HOME_ASSISTANT_IP="PASTE_YOUR_HA_IP_OR_HOSTNAME_HERE"
export HOME_ASSISTANT_TOKEN="PASTE_YOUR_LONG_LIVED_TOKEN_HERE"
export HOME_ASSISTANT_PORT="8123"

# Integration tests (test_home_assistant.py) — same credentials, do not edit:
export HOMEASSISTANT_TEST_IP="$HOME_ASSISTANT_IP"
export HOMEASSISTANT_ACCESS_TOKEN="$HOME_ASSISTANT_TOKEN"
export HOMEASSISTANT_PORT="$HOME_ASSISTANT_PORT"
