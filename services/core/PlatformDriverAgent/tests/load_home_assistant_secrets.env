# Source this file to load repo-root home_assistant.secrets.env (paste IP/token there only).
# Usage (from any directory):
#   set -a && source /path/to/volttron/services/core/PlatformDriverAgent/tests/load_home_assistant_secrets.env && set +a
#
# shellcheck shell=bash
if [ -n "${BASH_SOURCE[0]:-}" ]; then
  _HA_HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
else
  _HA_HERE="$(cd "$(dirname "$0")" && pwd)"
fi
# tests -> PlatformDriverAgent -> core -> services -> repo root
_HA_REPO="$(cd "$_HA_HERE/../../../.." && pwd)"
_SECRETS="$_HA_REPO/home_assistant.secrets.env"
if [ ! -f "$_SECRETS" ]; then
  echo "home_assistant.secrets.env not found at: $_SECRETS" >&2
  echo "Copy home_assistant.secrets.env.example to home_assistant.secrets.env at repo root and set IP + token." >&2
  return 1 2>/dev/null || exit 1
fi
set -a
# shellcheck disable=SC1090
source "$_SECRETS"
set +a
unset _HA_HERE _HA_REPO _SECRETS
